# SMTP Email Configuration
# IMPORTANT: For Gmail, get App Password from https://myaccount.google.com/apppasswords
# Steps:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create a new app password for 'Mail'
# 3. Copy the password WITHOUT SPACES
# 4. Paste it below in SENDER_PASSWORD
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_no_spaces
RECIPIENT_EMAIL=recipient@example.com

# Application Settings
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_THEMES=5
MAX_WORDS=250
REVIEW_WEEKS_RANGE=8

# Railway Deployment Configuration
# Add PORT environment variable in Railway dashboard
PORT=8000

# Scheduler Settings (for testing)
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_LOG_FILE=logs/scheduler.log
